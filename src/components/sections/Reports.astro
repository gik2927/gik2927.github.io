---
import Section from "../Section.astro";

import { reports } from "@cv";
---

<Section className={Astro.props.className} title="Reports">
	<ul class="flex flex-col gap-3">
		{
			reports.map(({ date, type, title, status, url, summary }) => (
				<li class="border-skin-hue/20 bg-skin-button-muted/50 rounded-md border p-4">
					<div class="flex flex-wrap items-center gap-2 text-sm">
						<span class="text-skin-muted">{date}</span>
						<span class="bg-skin-button-accent/20 text-skin-hue rounded px-2 py-0.5 text-xs font-medium">{type}</span>
						{status && <span class="text-skin-muted">{status}</span>}
					</div>
					<h4 class="mt-2 text-base font-medium">
						{
							url ? (
								<a href={url} target="_blank" rel="noopener noreferrer" class="hover:text-skin-hue decoration-dotted underline-offset-[5px] hover:underline">
									{title}
								</a>
							) : (
								title
							)
						}
					</h4>
					{summary && <p class="mt-2">{summary}</p>}
				</li>
			))
		}
	</ul>
</Section>
