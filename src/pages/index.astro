---
import Layout from "@/layouts/Layout.astro";

import About from "@/components/sections/About.astro";
import Education from "@/components/sections/Education.astro";
import Experience from "@/components/sections/Experience.astro";
import Hero from "@/components/sections/Hero.astro";
import Projects from "@/components/sections/Projects.astro";
import Reports from "@/components/sections/Reports.astro";
import Skills from "@/components/sections/Skills.astro";
import Teams from "@/components/sections/Teams.astro";
import Tail from "@/components/sections/Tail.astro";
import KeyboardManager from "@/components/KeyboardManager.astro";
import ThemeSwitch from "@/components/ThemeSwitch.astro";

import { basics, certificates, education, projects, reports, skills, teams, work } from "@cv";
const { name, label } = basics;
---

<Layout title={`${name} Portfolio - ${label}`}>
	<main class="relative grid max-w-7xl gap-12 p-8 max-sm:py-16 md:grid-cols-6 md:p-16 xl:gap-24 print:max-w-none print:grid-cols-1 print:gap-6">
		<div class="space-y-6 md:col-span-2 print:col-span-1 print:grid print:grid-cols-2 print:gap-5 print:space-y-0">
			<Hero />
			<About />
			<ThemeSwitch />
		</div>
		<div class="space-y-12 md:col-span-4 print:col-span-1 print:grid print:grid-cols-4 print:gap-2 print:space-y-0">
			{projects.length > 0 && <Projects className="print:hidden" />}
			{skills.length > 0 && <Skills className="print:hidden" />}
			{reports.length > 0 && <Reports className="print:hidden" />}
			{(education.length > 0 || certificates.length > 0) && <Education />}
			{teams.length > 0 && <Teams className="print:hidden" />}
			{work.length > 0 && <Experience className="print:col-span-3" />}
		</div>
		<Tail />
	</main>

	<KeyboardManager />
</Layout>

<style>
	@page {
		size: auto;
		margin: 0mm;
	}
	main {
		margin: auto;
		width: 100%;
	}
</style>
